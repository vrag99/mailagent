FROM node:22-alpine AS base

FROM base AS deps
RUN corepack enable pnpm
WORKDIR /app
# Copy workspace root files for pnpm workspace resolution
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY packages/sdk-ts/package.json packages/sdk-ts/package.json
COPY services/ui/package.json services/ui/package.json
RUN cd services/ui && pnpm install --frozen-lockfile

FROM base AS builder
RUN corepack enable pnpm
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/services/ui/node_modules ./services/ui/node_modules
COPY --from=deps /app/packages/sdk-ts/node_modules ./packages/sdk-ts/node_modules
COPY packages/sdk-ts/ packages/sdk-ts/
COPY services/ui/ services/ui/
COPY pnpm-workspace.yaml package.json ./
RUN cd services/ui && pnpm build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=builder /app/services/ui/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/services/ui/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/services/ui/.next/static ./.next/static

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "server.js"]

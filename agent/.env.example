# Inbox to watch (eg. test@example.com)
MAIL_DOMAIN=example.com
MAIL_USER=you 

# IMAP/SMTP auth (same password as the mailbox account)
MAIL_PASSWORD=

# Mail server hostname (docker-internal)
MAIL_HOST=mailserver

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
CLASSIFY_MODEL=google/gemini-flash-1.5
REPLY_MODEL=anthropic/claude-sonnet-4

# Optional
NOTIFY_WEBHOOK_URL=
CATCH_UP_ON_START=true

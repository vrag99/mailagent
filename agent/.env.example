# Inbox to watch (eg. test@example.com)
MAIL_DOMAIN=example.com
MAIL_USER=you 

# IMAP/SMTP auth (same password as the mailbox account)
MAIL_PASSWORD=

# Mail server (NOTE: edit as per your setup)
MAIL_HOST=mail.example.com

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
CLASSIFY_MODEL=openai/gpt-4.1-mini
REPLY_MODEL=google/gemini-3-flash-preview

# Optional
NOTIFY_WEBHOOK_URL=
CATCH_UP_ON_START=true
